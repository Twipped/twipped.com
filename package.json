{
  "name": "twipped.com",
  "version": "1.0.0",
  "description": "",
  "source": "src/index.html",
  "type": "module",
  "private": "true",
  "scripts": {
    "start": "node ./dev-stack.mjs",
    "deploy": "s3-deployer",
    "lint": "eslint ."
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "alias": {
    "common": "~/src/common"
  },
  "author": "Jocelyn Badgley <joc@twipped.com> (http://twipped.com/)",
  "license": "MIT",
  "devDependencies": {
    "@ahlec/s3-deployer": "^2.0.0",
    "express": "^5.2.1",
    "express-http-proxy": "^2.1.2",
    "express-static": "~1.2.6",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
  },
  "s3deployer": {
    "assets": {
      "**/*.{png,jpe?g,gif,svg,html}": {
        "contentType": "image/png",
        "cacheControl": "max-age=86400, s-maxage=2592000"
      },
      "**/*.{js,css}": {
        "cacheControl": "max-age=86400, s-maxage=2592000"
      },
      "**/*.{xml,json}": {
        "cacheControl": "max-age=3600, s-maxage=86400"
      },
      "**/.DS_Store": false
    },
    "bucket": {
      "name": "twipped.com",
      "region": "us-east-1"
    },
    "buildDir": "./static",
    "cloudfront": {
      "id": "E6KTDXQ5Y6G9D",
      "region": "us-east-1"
    }
  }
}
